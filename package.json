{
	"name": "@grml/lib-template",
	"version": "0.0.0",
	"description": "ESM-friendly TypeScript library template.",
	"type": "module",
	"main": "dist/index.js",
	"types": "dist/types/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/types/index.d.ts",
			"default": "./dist/index.js"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsc",
		"typecheck": "tsc --noEmit",
		"lint": "eslint .",
		"test": "node --import tsx --test \"tests/**/*.test.ts\""
	},
	"keywords": [
		"typescript",
		"esm",
		"template",
		"library"
	],
	"author": "",
	"license": "ISC",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/grMLEqomlkkU5Eeinz4brIrOVCUCkJuN/lib-template.git"
	},
	"devDependencies": {
		"@types/node": "^25.9.3",
		"eslint": "^10.5.0",
		"tsx": "^4.21.0",
		"typescript": "^6.0.2",
		"typescript-eslint": "^8.61.1"
	}
}
